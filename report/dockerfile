FROM python:3.10-slim

# 1. Install cron inside the container
RUN apt-get update && apt-get install -y cron && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 2. Copy your script, template, and inputs into the container
COPY generate_report.py .
COPY template.html .
COPY inputs.json .

# 3. Create the output folder where files will be saved
RUN mkdir -p /app/output

# 4. Force the script to run ONCE immediately when the container starts
# so you don't have to wait until Monday at 11 AM just to see if it works!
RUN python generate_report.py

# 5. Set up the Cron schedule (Mondays and Fridays at 11:00 AM)
RUN echo "0 11 * * 1,5 cd /app && /usr/local/bin/python generate_report.py >> /var/log/cron.log 2>&1" > /etc/cron.d/report-cron
RUN chmod 0644 /etc/cron.d/report-cron
RUN crontab /etc/cron.d/report-cron
RUN touch /var/log/cron.log

# 6. Open port 8080 to the outside world
EXPOSE 8080

# 7. Start Cron, start the web server, and keep the container alive
CMD cron && cd /app/output && python -m http.server 8080